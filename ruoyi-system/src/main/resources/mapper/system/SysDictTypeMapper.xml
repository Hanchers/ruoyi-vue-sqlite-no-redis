<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysDictTypeMapper">

	<sql id="selectDictTypeVo">
        select dict_id, dict_name, dict_type, status, create_by, create_time, remark
		from sys_dict_type
    </sql>

	<select id="selectDictTypeList" parameterType="SysDictType" resultType="com.ruoyi.common.core.domain.entity.SysDictType">
	    <include refid="selectDictTypeVo"/>
		<where>
		    <if test="dictName != null and dictName != ''">
				AND dict_name like concat('%', #{dictName}, '%')
			</if>
			<if test="status != null and status != ''">
				AND status = #{status}
			</if>
			<if test="dictType != null and dictType != ''">
				AND dict_type like concat('%', #{dictType}, '%')
			</if>
			<if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
				and strftime('%Y%m%d', create_time) &gt;= strftime('%Y%m%d', #{params.beginTime})
			</if>
			<if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
				and strftime('%Y%m%d', create_time) &lt;= strftime('%Y%m%d', #{params.endTime})
			</if>
	    </where>
	</select>

	<select id="selectDictTypeAll" resultType="com.ruoyi.common.core.domain.entity.SysDictType">
		<include refid="selectDictTypeVo"/>
	</select>

	<select id="selectDictTypeByType" parameterType="String" resultType="com.ruoyi.common.core.domain.entity.SysDictType">
		<include refid="selectDictTypeVo"/>
		where dict_type = #{dictType}
	</select>

	<select id="checkDictTypeUnique" parameterType="String" resultType="com.ruoyi.common.core.domain.entity.SysDictType">
		<include refid="selectDictTypeVo"/>
		where dict_type = #{dictType} limit 1
	</select>

</mapper>
